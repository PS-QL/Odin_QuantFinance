# ====================================================================
# Odin Language & MSVC Compiler Artifacts
# ====================================================================
# Ignore the compiled Windows executable binaries
*.exe
*.dll
*.pdb

# Ignore temporary object compilation frames generated by the MSVC linker
*.obj

# ====================================================================
# DuckDB Local Storage Caches & Quant Results
# ====================================================================
# Ignore the actual permanent/temporary database binary data files
# (This keeps your massive multi-gigabyte financial archives off GitHub)
duckdb/*.db
duckdb/*.db.wal

# Optional: Ignore the exported analytical results spreadsheet
# (Comment this out with a # if you WANT to commit your final CSV sheets to git)
duckdb/quant_results.csv

# ====================================================================
# Windows System & Code Editor Artifacts
# ====================================================================
# Ignore Windows thumbnail files and directory configurations
Thumbs.db
ehthumbs.db
Desktop.ini

# Ignore VS Code configuration directory paths if you use it
.vscode/
.idea/
